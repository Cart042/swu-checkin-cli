# 西南大学校园网打卡配置（命令行版）

# 方式 1：单账号配置
SWU_USERNAME=your_username
SWU_PASSWORD=your_password

# 方式 2：多账号 JSON 配置
# 如果设置了 SWU_USERS，将优先使用它并忽略单账号配置。
# SWU_USERS=[{"username": "user1", "password": "pwd1"}, {"username": "user2", "password": "pwd2"}]

# 签到并发线程数，默认 3
SWU_MAX_WORKERS=3

# 日志输出级别：DEBUG / INFO / WARNING / ERROR
SWU_LOG_LEVEL=INFO

# 学校官网代理配置
# 海外 VPS 如需运行，需要服务器能直连学校官网，或有一个可信的中国大陆网络出口。
# 默认 SWU_PROXY_MODE=auto：优先读取 SWU_PROXY_URL；未配置时自动读取 HTTPS_PROXY / HTTP_PROXY / ALL_PROXY。
# 可设为 manual 只读取 SWU_PROXY_URL，或设为 off 禁用代理。
# 支持 http://、https://、socks4://、socks5:// 形式；如果代理需要认证，可填写用户名和密码。
# SWU_PROXY_MODE=auto
# SWU_PROXY_URL=http://127.0.0.1:7890
# SWU_PROXY_USERNAME=
# SWU_PROXY_PASSWORD=

# 消息推送通道配置，按需填写。
# 1. 钉钉机器人
PUSH_DINGTALK_TOKEN=
PUSH_DINGTALK_SECRET=

# 2. 企业微信群机器人
PUSH_QYWX_KEY=

# 3. Bark (iOS)
PUSH_BARK_KEY=
PUSH_BARK_URL=https://api.day.app

# 4. Server 酱
PUSH_SERVERCHAN_KEY=

# 5. PushDeer
PUSH_PUSHDEER_KEY=
